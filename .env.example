# ============================================================================
# FinzApp Environment Variables
# ============================================================================

# Base de datos PostgreSQL
# IMPORTANTE: Cambiar contraseña en producción
POSTGRES_DB=finzapp
POSTGRES_USER=finzapp_user
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://finzapp_user:change_me_in_production@db:5432/finzapp

# Redis Cache
# IMPORTANTE: Cambiar contraseña en producción
REDIS_PASSWORD=change_redis_password
REDIS_URL=redis://:change_redis_password@redis:6379

# JWT Authentication
# IMPORTANTE: Generar claves fuertes y únicas en producción
# Ejecutar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=super_secret_jwt_key_min_32_characters_long
JWT_REFRESH_SECRET=super_secret_refresh_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# API Configuration
PORT=3000
NODE_ENV=development

# API Keys
# IMPORTANTE: Generar claves seguras en producción
INGEST_API_KEY=your_companion_api_key_here

# NLP Service
NLP_SERVICE_URL=http://nlp-service:8000

# Frontend Configuration
VITE_API_URL=http://localhost:3000/api/v1

# Logging
LOG_LEVEL=info

# Features
ENABLE_MOCK_DATA=false
ENABLE_SMS_IMPORT=true
ENABLE_PUSH_IMPORT=true
ENABLE_CSV_EXPORT=true
ENABLE_PDF_REPORTS=true

# Limits
MAX_MONTHLY_TRANSACTIONS=10000
MAX_API_REQUESTS_PER_MINUTE=100

# Email (opcional, para notificaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@finzapp.co

# Sentry (opcional, para error tracking)
SENTRY_DSN=

# Google Analytics (opcional)
GOOGLE_ANALYTICS_ID=
